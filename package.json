{
  "name": "flowai-platform",
  "version": "0.1.0",
  "private": true,
  "description": "FlowAI greenfield platform for business-to-workflow chatbot generation.",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r typecheck",
    "typecheck": "pnpm -r typecheck",
    "demo:flowai": "pnpm build && node examples/flowai-demo/visible-mvp-demo.mjs",
    "smoke:flowai-ai": "pnpm --filter @flowai/ai-builder-orchestrator build && node examples/flowai-demo/live-ai-extraction-smoke.mjs",
    "dev:api": "pnpm --filter @flowai/api dev",
    "dev:flowai-studio": "pnpm --filter @flowai/studio dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
