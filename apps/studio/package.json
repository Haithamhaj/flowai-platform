    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@flowai/ai-builder-orchestrator": "workspace:*",
    "@flowai/business-understanding": "workspace:*",
    "@flowai/channel-adapters": "workspace:*",
    "@flowai/exporters": "workspace:*",
    "@flowai/runtime-core": "workspace:*",
    "@flowai/source-ingestion": "workspace:*",
    "@flowai/source-review": "workspace:*",
    "@flowai/workflow-dsl": "workspace:*",
    "@flowai/workflow-generator": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
